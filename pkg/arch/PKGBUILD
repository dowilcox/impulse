# Maintainer: Impulse Contributors
pkgname=impulse
pkgver=__VERSION__
pkgrel=1
pkgdesc='Terminal-first development environment (Qt6)'
arch=('x86_64')
url='https://github.com/dowilcox/impulse'
license=('GPL-3.0-only')
depends=('qt6-base' 'qt6-declarative' 'qt6-webengine' 'qt6-quickcontrols2')
makedepends=('rust' 'cargo' 'cmake' 'qt6-tools')
source=('impulse' 'dev.impulse.Impulse.desktop' 'impulse-logo.svg')
sha256sums=('SKIP' 'SKIP' 'SKIP')

package() {
    install -Dm755 "$srcdir/impulse" "$pkgdir/usr/bin/impulse"
    install -Dm644 "$srcdir/dev.impulse.Impulse.desktop" \
        "$pkgdir/usr/share/applications/dev.impulse.Impulse.desktop"
    install -Dm644 "$srcdir/impulse-logo.svg" \
        "$pkgdir/usr/share/icons/hicolor/scalable/apps/dev.impulse.Impulse.svg"
}
